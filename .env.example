# Copy this file to .env and fill in your real values.
# NEVER share .env or commit it to GitHub.

# A secret word YOU choose — must match what you enter in Meta webhook settings
VERIFY_TOKEN=beantol_verify_2026

# From Meta Developer → Your App → Messenger → Access Tokens (Beantol page)
PAGE_ACCESS_TOKEN=your_page_access_token_here

# From https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional — cheaper/faster model for testing
OPENAI_MODEL=gpt-4o-mini

# Port (Render sets this automatically; 3000 is fine locally)
PORT=3000

# Secret for admin handoff endpoints (choose a long random string)
ADMIN_SECRET=your_admin_secret_here

# Minutes of admin idle before bot auto-resumes after you reply in Business Suite (default 15)
HANDOFF_ADMIN_IDLE_MINUTES=15

# Legacy — unused by soft handoff; kept for compatibility
# HANDOFF_TIMEOUT_HOURS=24

# Send this exact message from Business Suite to turn the bot back on for that customer
ADMIN_RESUME_COMMANDS=#bot

# Message the bot sends after you use the resume command (optional)
# BOT_RESUME_REPLY=Our chat assistant is back on — ask us anything about coffee or orders.

# Wait before sending resume message after #bot (ms) — helps after human replies (default 1200)
RESUME_SEND_DELAY_MS=1200

# Public URL of your Render app (for admin dashboard + email resume links)
PUBLIC_BASE_URL=https://beantol-bot.onrender.com

# Optional — how many user+bot messages to remember per customer (default 20)
# CHAT_HISTORY_MAX_MESSAGES=20
# CHAT_HISTORY_TTL_HOURS=24
# OUTBOUND_MID_TTL_HOURS=168
# OUTBOUND_MID_MAX_PER_USER=80

# Wait this many ms before replying so rapid messages (hi / hello / are you there?) merge into one reply
# MESSAGE_DEBOUNCE_MS=2500

# After "here's my payment" text, wait up to this long for the screenshot before replying
# PAYMENT_PROOF_WAIT_MS=10000

# Live agent handoff hours (Philippine time by default). No customer handoff 9 PM–9 AM.
# SUPPORT_TIMEZONE=Asia/Manila
# SUPPORT_HOURS_START=9
# SUPPORT_HOURS_END=21

# Out-of-stock products (comma-separated). Fallback when Inventory sheet tab is not used.
# Prefer live stock: add an "Inventory" tab to your Google Sheet (auto-seeded). Edit at /admin/inventory/view
# UNAVAILABLE_PRODUCTS=beantol prime
# UNAVAILABLE_PRODUCTS=beantol prime,brazil cerrado
# GOOGLE_INVENTORY_SHEET_TAB=Inventory
# INVENTORY_SHEET_ENABLED=false
# INVENTORY_CACHE_MINUTES=5
# INVENTORY_LOW_STOCK_THRESHOLD=3
#
# Analytics — logs each customer message to Events tab (auto-created)
# GOOGLE_EVENTS_SHEET_TAB=Events
# EVENTS_LOG_ENABLED=false
#
# Phase 4 — sales & appointments
# SALES_FOLLOWUP_DAYS=3
# GOOGLE_APPOINTMENTS_SHEET_TAB=Appointments
# APPOINTMENT_CAPTURE_ENABLED=false
# RECOMMEND_SESSION_HOURS=24
# QUOTE_CONFIRM_SESSION_HOURS=4
# POST_QUOTE_SESSION_HOURS=4
# WELCOME_SENT_TTL_HOURS=168
# SHOP_ADDRESS=Holy Family Village 2, Governor Cuenco Avenue, Banilad, Cebu City (beside the guardhouse).
# SHOP_HOURS=Monday–Friday, 9:00 AM–6:00 PM (shop closed on weekends).

# Optional — override POST /{page-id}/subscribed_apps fields (default tries message_echoes too)
# WEBHOOK_SUBSCRIBED_FIELDS=messages,messaging_postbacks,message_echoes

# Optional — Facebook PAGE numeric ID (NOT Instagram ID — IG IDs often start with 178414)
# Page → About → Page ID. Example: 124972487369170
PAGE_ID=

# Optional — display on /admin when Meta API cannot verify IG link (pages_read_engagement)
# INSTAGRAM_USERNAME=beantol
# INSTAGRAM_ACCOUNT_ID=

# Log every webhook with #bot in text (debug Business Suite)
# DEBUG_WEBHOOK=true

# Email when a customer asks for a human or delivery (default below if unset)
HANDOFF_NOTIFY_EMAIL=cgccjustin@gmail.com

# Minutes between delivery alert emails for the same customer (default 240)
DELIVERY_ALERT_COOLDOWN_MINUTES=240

# --- Email on Render: use Resend (HTTPS). Gmail SMTP often times out on Render. ---
# Sign up at https://resend.com → API Keys → create key (starts with re_)
RESEND_API_KEY=re_your_resend_api_key_here
# Free tier without a domain: use onboarding@resend.dev (sends only to your Resend account email)
EMAIL_FROM=onboarding@resend.dev

# --- Optional: Gmail SMTP for local dev only ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_gmail_address@gmail.com

# --- Multi-tenant (optional) ---
# If unset, one legacy tenant is built from PAGE_ACCESS_TOKEN + GOOGLE_* env below.
# Copy config/tenants.example.json → config/tenants.json (local, gitignored), or set on Render:
# TENANTS_JSON={"tenants":[{...}]}
# See docs/MULTI-TENANT.md

# --- RAG knowledge base (pricing, FAQ, products) ---
# Business facts: Google Doc (production) or knowledge/sources/*.md (local dev).
# Behavior rules stay in system-rules.js.
# RAG_ENABLED=false disables vector search (uses source files only)
# RAG_TOP_K=6
# RAG_EMBEDDING_MODEL=text-embedding-3-small
#
# When GOOGLE_* vars are set, Google Docs sync on server start is ON by default.
# Set RAG_SYNC_ON_STARTUP=false to disable auto-sync on boot (manual /admin/sync-knowledge only).

# Google Docs sync — share each Doc with the service account email (Viewer)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",... entire JSON one line ...}
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json
# GOOGLE_KNOWLEDGE_DOC_IDS=YOUR_DOC_ID:beantol-knowledge
# After editing Docs: GET /admin/sync-knowledge?token=ADMIN_SECRET (or auto on restart if sync on startup)

# --- Lead capture (Google Sheet) ---
# Enable Google Sheets API in the same Cloud project as Drive.
# Create a Sheet with tab named "Leads" (or set GOOGLE_LEADS_SHEET_TAB).
# Share the Sheet with your service account email as Editor.
# GOOGLE_LEADS_SHEET_ID=your_google_sheet_id_from_url
# GOOGLE_LEADS_SHEET_TAB=Leads
# GOOGLE_ORDERS_SHEET_TAB=Orders
# GOOGLE_QUOTES_SHEET_TAB=Quotes
# QUOTE_CAPTURE_ENABLED=false
# QUOTE_VALID_DAYS=7
# LEAD_NOTIFY_EMAIL=cgccjustin@gmail.com
# ORDER_NOTIFY_EMAIL=cgccjustin@gmail.com
# LEAD_CAPTURE_ENABLED=false
# ORDER_CAPTURE_ENABLED=false
#
# Leads tab columns (bot fills A–J; team edits K–N):
#   Team status: New | Contacted | Follow-up | Won | Lost
#   Assigned to, Notes, Next action
# Orders tab: bot creates/updates open orders; team edits Order status & Notes in Sheet
